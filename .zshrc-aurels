export PATH="$PATH:/Applications/Visual Studio Code.app/Contents/Resources/app/bin"

## Aliases

alias ohmyzsh-update="/usr/bin/env ZSH=$ZSH zsh $ZSH/tools/check_for_upgrade.sh"
alias sublime="/Applications/Sublime\ Text.app/Contents/SharedSupport/bin/subl"
alias runeslint="node_modules/eslint/bin/eslint.js --ext .js --ext .jsx ."
alias vmrun="/Applications/VMware\ Fusion.app/Contents/Library/vmrun"
alias gitdiff="git icdiff"
alias sublime=subl
alias dc="docker compose"
alias wezterm=/Applications/WezTerm.app/Contents/MacOS/wezterm

